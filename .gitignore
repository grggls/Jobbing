# Environment and runtime
.env
.venv/
.venv-vm/
__pycache__/
*.pyc
*.egg-info/
.fuse_hidden*

# OS / editor
.DS_Store

# Obsidian — commit config, exclude machine-specific state
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache

# Kanban — exclude large derived-data snapshot
kanban/snapshot.json

