# Environment and runtime
.env
.venv/
.venv-vm/
.venv-local/
__pycache__/
*.pyc
*.egg-info/
.fuse_hidden*

# OS / editor
.DS_Store
=*

# Obsidian — commit config, exclude machine-specific state
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache

# Kanban — board is committed, company data is private
kanban/snapshot.json
kanban/companies/
kanban/interviews/

# Personal data — never commit
CONTEXT.md
BOOKMARKS.md
CV-*.pdf
companies/

# Notion queue (transient)
notion_queue/
notion_queue_results/

# Scan results (personal)
scan_results/**
!scan_results/.gitkeep
Bookmarks
